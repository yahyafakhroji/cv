---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection, getEntry } from 'astro:content';
import { sortExperience } from '@/lib/content';
const exp = sortExperience(await getCollection('experience'));
const profile = await getEntry('profile', 'profile');
const skills = await getEntry('skills', 'skills');
const projects = await getEntry('projects', 'projects');
---
<BaseLayout>
  <main style="padding:4rem">
    <p>name: {profile?.data.name}</p>
    <p>jobs: {exp.length}</p>
    <p>first: {exp[0]?.id}</p>
    <p>skills: {skills?.data.rows.length}</p>
    <p>groups: {projects?.data.groups.length}</p>
  </main>
</BaseLayout>
