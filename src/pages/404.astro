---
import BaseLayout from '@/layouts/BaseLayout.astro';
---
<BaseLayout title="404 — Page not found · Yahya Fakhroji" description="That page could not be found." path="/404">
  <main class="min-h-screen flex flex-col justify-center items-center text-center px-[clamp(20px,5vw,64px)] gap-[clamp(18px,3vw,28px)]">
    <div class="font-display font-extrabold leading-[0.9] tracking-[-0.04em] text-[clamp(96px,22vw,260px)]">404</div>
    <p class="text-[clamp(18px,2vw,24px)] text-muted max-w-[460px] leading-[1.5]">This page wandered off. Let's get you back to the start.</p>
    <a href="/" class="inline-block font-semibold text-paper bg-ink rounded-full px-6 py-3 no-underline transition-colors hover:bg-accent">Back home&nbsp;↗</a>
  </main>
</BaseLayout>
