---
import { getEntry } from 'astro:content';
import SectionHeader from '@/components/layout/SectionHeader.astro';
const edu = (await getEntry('education', 'education'))!.data.items;
const langs = (await getEntry('languages', 'languages'))!.data.items;
---
<section id="education" aria-labelledby="edu-h" class="py-[clamp(48px,7vw,100px)]">
  <div class="max-w-[1200px] mx-auto px-[clamp(20px,5vw,64px)]">
    <SectionHeader no="05" label="Education & Languages" />
    <h2 id="edu-h" class="sr-only">Education and Languages</h2>
    <div class="flex flex-wrap gap-[clamp(28px,5vw,72px)]">
      <div data-reveal class="flex-[2_1_420px] flex flex-col">
        {edu.map((e) => (
          <div class="flex flex-wrap justify-between items-baseline gap-x-4 gap-y-1 py-[18px] border-t border-line">
            <div>
              <div class="font-display text-[clamp(19px,2.2vw,26px)] font-bold tracking-[-0.02em]">{e.school}</div>
              <div class="text-[15px] text-muted mt-1">{e.degree} · {e.detail}</div>
            </div>
            <span class="text-[13px] font-semibold text-muted whitespace-nowrap">{e.period}</span>
          </div>
        ))}
      </div>
      <div data-reveal data-reveal-delay="120" class="flex-[1_1_240px] flex flex-col">
        {langs.map((l) => (
          <div class="flex justify-between items-baseline gap-3 py-[14px] border-t border-line">
            <span class="font-semibold">{l.name}</span>
            <span class="text-[13px] text-muted text-right">{l.level}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
