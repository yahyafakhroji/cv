---
const links = [
  { href: '#profile', label: 'Profile' },
  { href: '#experience', label: 'Experience' },
  { href: '#projects', label: 'Projects' },
  { href: '#education', label: 'Education' },
  { href: '#contact', label: 'Contact' },
];
---
<nav aria-label="Primary" class="fixed top-0 inset-x-0 z-50 backdrop-blur-md bg-paper/80 border-b border-line/60">
  <div class="max-w-[1200px] mx-auto px-[clamp(20px,5vw,64px)] h-[60px] flex items-center justify-between gap-4">
    <a href="#top" class="flex items-center gap-2 font-display font-extrabold text-[18px] tracking-[-0.02em] text-ink no-underline">
      <span class="w-[9px] h-[9px] rounded-full bg-accent"></span>Yahya
    </a>
    <div class="hidden md:flex items-center gap-x-7 text-[13px] font-semibold text-muted">
      {links.map((l) => (
        <a href={l.href} data-navlink class="no-underline transition-colors hover:text-accent">{l.label}</a>
      ))}
    </div>
    <a href="/Yahya_Fakhroji_CV.pdf" download class="inline-flex items-center gap-1.5 text-[13px] font-semibold text-paper bg-ink rounded-full px-4 py-2 no-underline transition-colors hover:bg-accent">Download CV</a>
  </div>
</nav>
